<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/liquid_dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📱 Aplicaciones"
        android:textSize="22sp"
        android:textColor="#004D40"
        android:fontFamily="@font/google_sans_medium"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:gravity="center"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3">

        <Button android:id="@+id/app_calculator" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="🧮\nCalculadora" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

        <Button android:id="@+id/app_camera" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="📷\nCámara" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

        <Button android:id="@+id/app_files" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="📁\nArchivos" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

        <Button android:id="@+id/app_settings" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="⚙️\nAjustes" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

        <Button android:id="@+id/app_flashlight" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="🔦\nLinterna" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

        <Button android:id="@+id/app_calendar" android:layout_width="0dp" android:layout_height="75dp"
            android:layout_columnWeight="1" android:layout_margin="8dp"
            android:background="@drawable/liquid_button_small"
            android:text="📅\nCalendario" android:textColor="#004D40"
            android:fontFamily="@font/google_sans_medium" android:textSize="13sp"/>

    </GridLayout>

    <Button
        android:id="@+id/btn_close_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar"
        android:background="@drawable/liquid_button_small"
        android:textColor="#004D40"
        android:fontFamily="@font/google_sans_medium"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

</LinearLayout>
