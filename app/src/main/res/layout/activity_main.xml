<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_turquoise"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Hora grande -->
    <TextView
        android:id="@+id/tv_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="21:21"
        android:textSize="48sp"
        android:textColor="#006064"
        android:layout_marginBottom="32dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Avatar central -->
    <ImageView
        android:id="@+id/avatar"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/avatar_pensativo"
        android:layout_marginBottom="8dp"/>

    <!-- Nube de pensamiento (mejorada) -->
    <ImageView
        android:id="@+id/thought_bubble"
        android:layout_width="60dp"
        android:layout_height="50dp"
        android:src="@drawable/thought_bubble"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center_horizontal"/>

    <!-- Indicador de llamada entrante con ondas turquesa -->
    <LinearLayout
        android:id="@+id/calling_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <!-- Barras de sonido animadas -->
        <ImageView
            android:id="@+id/wave_bars"
            android:layout_width="80dp"            android:layout_height="60dp"
            android:src="@drawable/wave_bars"
            android:layout_marginBottom="12dp"
            android:layout_gravity="center_horizontal"/>

        <!-- Texto con fondo degradado turquesa -->
        <TextView
            android:id="@+id/speech_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/sound_waves_background"
            android:text="Te están llamando"
            android:textSize="20sp"
            android:textColor="#006064"
            android:textStyle="bold"
            android:paddingLeft="24dp"
            android:paddingTop="12dp"
            android:paddingRight="24dp"
            android:paddingBottom="12dp"
            android:elevation="4dp"/>

    </LinearLayout>

    <!-- Botones binarios gigantes -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_accept"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_green"
            android:text="✓"
            android:textSize="70sp"
            android:textColor="#FFFFFF"/>

        <Space android:layout_width="48dp" android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btn_reject"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_red"
            android:text="✕"
            android:textSize="70sp"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</LinearLayout>
