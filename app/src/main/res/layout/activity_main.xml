<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/header_gradient"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp">

    <!-- Avatar en la parte superior -->
    <ImageView
        android:id="@+id/avatar"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/avatar_pensativo"
        android:layout_marginBottom="16dp"/>

    <!-- Texto de estado -->
    <TextView
        android:id="@+id/speech_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Te están llamando"
        android:textSize="18sp"
        android:textColor="#006064"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Dashboard de 4 botones (2x2) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:padding="8dp">

        <!-- 📞 LLAMAR -->
        <Button
            android:id="@+id/btn_call"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/dashboard_button"
            android:drawableTop="@drawable/ic_phone"
            android:text="Llamar"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <!-- 💬 MENSAJES -->
        <Button
            android:id="@+id/btn_messages"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/dashboard_button"
            android:drawableTop="@drawable/ic_message"
            android:text="Mensajes"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <!-- 👥 CONTACTOS -->
        <Button
            android:id="@+id/btn_contacts"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/dashboard_button"
            android:drawableTop="@drawable/ic_contacts"
            android:text="Contactos"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <!-- ➕ MÁS -->
        <Button
            android:id="@+id/btn_more"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="8dp"
            android:background="@drawable/dashboard_button"
            android:drawableTop="@drawable/ic_more"
            android:text="Más"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

    </GridLayout>

</LinearLayout>
