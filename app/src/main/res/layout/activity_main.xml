<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo animado -->
    <View
        android:id="@+id/animated_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/animated_background"/>

    <!-- Contenido principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <!-- Hora -->
        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="21:21"
            android:textSize="48sp"
            android:textColor="#006064"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Avatar -->
        <ImageView
            android:id="@+id/avatar"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/avatar_pensativo"
            android:layout_marginBottom="16dp"/>

        <!-- Texto -->
        <TextView
            android:id="@+id/speech_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido a OASIS"
            android:textSize="18sp"
            android:textColor="#006064"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Botones -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:padding="8dp">

            <Button android:id="@+id/btn_call" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:background="@drawable/dashboard_button" android:drawableTop="@drawable/ic_phone" android:text="Llamar" android:textSize="16sp" android:textColor="#FFFFFF"/>

            <Button android:id="@+id/btn_messages" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:background="@drawable/dashboard_button" android:drawableTop="@drawable/ic_message" android:text="Mensajes" android:textSize="16sp" android:textColor="#FFFFFF"/>

            <Button android:id="@+id/btn_contacts" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:background="@drawable/dashboard_button" android:drawableTop="@drawable/ic_contacts" android:text="Contactos" android:textSize="16sp" android:textColor="#FFFFFF"/>

            <Button android:id="@+id/btn_more" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:background="@drawable/dashboard_button" android:drawableTop="@drawable/ic_more" android:text="Más" android:textSize="16sp" android:textColor="#FFFFFF"/>

        </GridLayout>

        <!-- Franja azul rey inferior -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bottom_royal_blue"
            android:layout_gravity="bottom"/>

    </LinearLayout>

</FrameLayout>
