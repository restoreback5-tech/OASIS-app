<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#30FFFFFF">
    <item android:id="@android:id/background">
        <layer-list>
            <!-- Sombra exterior suave -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#00000000"/>
                </shape>
            </item>
            <!-- Círculo principal blanco -->
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
                <shape android:shape="oval">
                    <solid android:color="#E6FFFFFF"/>
                    <stroke android:width="1dp" android:color="#FFFFFFFF"/>
                    <gradient android:startColor="#FFFFFFFF" android:endColor="#D0FFFFFF" android:angle="135"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
