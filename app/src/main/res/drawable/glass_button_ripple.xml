<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#30FFFFFF">
    <item android:id="@android:id/background">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="40dp"/>
                    <solid android:color="#20000000"/>
                </shape>
            </item>
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="40dp"/>
                    <solid android:color="#99FFFFFF"/>
                    <stroke android:width="1dp" android:color="#FFFFFFFF"/>
                    <gradient android:startColor="#FFFFFFFF" android:endColor="#80FFFFFF" android:angle="135"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
