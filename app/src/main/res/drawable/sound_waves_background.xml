<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Fondo con degradado turquesa -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E0F7FA"
                android:centerColor="#26C6DA"
                android:endColor="#00BCD4"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="20dp"/>
            <padding
                android:left="24dp"
                android:top="16dp"
                android:right="24dp"
                android:bottom="16dp"/>
        </shape>
    </item>
    
    <!-- Borde turquesa oscuro -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#006064"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    
</layer-list>
